<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppQuiz.MainPage"
             Padding="20">

    <ScrollView>
        <VerticalStackLayout Spacing="30"
                             VerticalOptions="Center">
            <Label x:Name="ScoreLabel"
                   Text="Punteggio: 0"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}"/>

            <Label x:Name="DomandaLabel"
                    Text="DOMANDA"
                   FontSize="12"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>

            <Label x:Name="QuestionTextLabel"
                   Text="Caricamento domanda..."
                   FontSize="24"
                   HorizontalTextAlignment="Center"
                   FontAttributes="Bold"
                   TextColor="White"/>

            <Image x:Name="QuestionImage"
                HeightRequest="100"
                Aspect="AspectFit"/>

            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                <Button x:Name="TrueButton"
                    Text="VERO"
                    Clicked="OnAnswer_Clicked"
                    CommandParameter="true"
                    WidthRequest="130"
                    HeightRequest="60"
                    FontSize="18"
                    BackgroundColor="#27ae68"
                    CornerRadius="10"
                    TextColor="White"/>
                <Button x:Name="FalseButton"
                    Text="FALSO"
                    Clicked="OnAnswer_Clicked"
                    CommandParameter="false"
                    WidthRequest="130"
                    HeightRequest="60"
                    FontSize="18"
                    BackgroundColor="#c0392b"
                    CornerRadius="10"
                    TextColor="White"/>
            </HorizontalStackLayout>

            <Entry x:Name="UserAnswer"
                   Placeholder="Scrivi la risposta..."/>
            
            <Button x:Name="SendUserAnswer"
                    Text="CONFERMA RISPOSTA"
                    Clicked="OnAnswer_Clicked"
                    FontSize="18"
                    BackgroundColor="{StaticResource Primary}"/>

            <Button 
                x:Name="BtnResult"
                WidthRequest="200" 
                HeightRequest="30"
                IsVisible="False"
                Text="Vai a risultati"
                Clicked="btnResult_Clicked" />      
        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
