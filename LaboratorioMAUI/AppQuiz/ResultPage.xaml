<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppQuiz.ResultPage"
             Title="ResultPage"
             Padding="20">
    <VerticalStackLayout
        VerticalOptions="Center"
        Spacing="20">
        
        <Label 
            Text="QUIZ COMPLETATO!"
            FontSize="30"
            TextColor="White"
            HorizontalOptions="Center"/>

        <Frame
            BackgroundColor="#1f211f"
            BorderColor="#535954"
            CornerRadius="15">
            <VerticalStackLayout>

                <Label 
                    Text="Il tuo punteggio"
                    TextColor="White"
                    HorizontalOptions="Center"/>

                <Label 
                    x:Name="lblScore"
                    Text="0"
                    FontSize="40"
                    TextColor="#53995e"
                    HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </Frame>
        <HorizontalStackLayout
            HorizontalOptions="Center"
            Spacing = "20">
            <Entry x:Name="UserName"
                   Placeholder="Inserisci il nome..."
                   WidthRequest="400"/>
            <Button x:Name="btnSaveUserName"
                    Text="SALVA"
                    Clicked="btnSaveUserName_Clicked"
                    TextColor="White"
                    BackgroundColor="DarkBlue"
                    WidthRequest="400"/>
        </HorizontalStackLayout>
        <Label 
            x:Name="lblBestScore"
            Text="🏆 Miglior Punteggio: "
            FontSize="20"
            TextColor="Gold"
            FontAttributes="Bold"
            HorizontalOptions="Center"/>

        <Button
            x:Name="btnPlayAgain"
            Text="GIOCA ANCORA"
            Clicked="btnPlayAgain_Clicked"
            TextColor="White"
            BackgroundColor="DarkBlue"
            CornerRadius="20"
            />


    </VerticalStackLayout>
</ContentPage>