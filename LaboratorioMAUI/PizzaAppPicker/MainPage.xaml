<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzaAppPicker.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Frame>
                <Label Text="MENU PIZZE"
                       FontSize="30"
                       HorizontalOptions="Center"/>
            </Frame>
            <Label Text="Seleziona tipo di pizza"/>
            <Picker x:Name="pickPizze"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
