<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppDiario.MainPage">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">
            <Label 
                Text="IL MIO DIARIO"
                FontSize="24"
                HorizontalOptions="Center"
                FontAttributes="Bold" />
            <Entry 
                x:Name="entTitolo"
                Placeholder="Inserisci Titolo" />
            <Entry 
                x:Name="entTesto"
                Placeholder="Inserisci Testo" />
            <Button
                x:Name="btSalva"
                Text="SALVA NOTA"
                BackgroundColor="Green"
                TextColor="White"
                Clicked="OnSalvaClicked"/>
            <Button 
                x:Name="btLeggi"
                Text="LEGGI TUTTE LE NOTE"
                BackgroundColor="Gray"
                TextColor="White"
                Clicked="OnLeggiClicked" />
            <BoxView 
                HeightRequest="1"
                Color="Silver"/>
            <Label
                Text="Note salvate nel file: "
                FontAttributes="Italic"/>
            <Editor 
                x:Name="ediDisplay"
                HeightRequest="300" 
                IsReadOnly="True" 
                BackgroundColor="GhostWhite"/>

            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
